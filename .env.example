# Copy this file to .env.local and fill in your real key
# Never commit .env.local

# Hugging Face Router API token
HUGGINGFACE_API_KEY=hf_your_token_here

# Optional: override the default model
# If you set an unsupported model, the API will return `model_not_supported`.
# Note: the `:fastest` suffix is a Hugging Face Router convention (Inference Providers).
HF_MODEL=google/gemma-2-2b-it:fastest
